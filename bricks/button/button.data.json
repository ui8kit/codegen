    "variant.link": {
      "props": {
        "Variant": "link"
      }
    },
    "variant.outline": {
      "props": {
        "Size": "sm",
        "Variant": "outline"
      }
    },
    "variant.secondary": {
      "props": {
        "Size": "default",
        "Variant": "secondary"
      }
