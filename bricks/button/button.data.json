{
  "$schema": "../../schemas/data.schema.json",
  "id": "ui.button",
  "showcase": {
    "size.icon": {
      "props": {
        "AriaLabel": "Settings",
        "Size": "icon",
        "Variant": "default"
      }
    },
    "size.lg": {
      "props": {
        "Size": "lg",
        "Variant": "default"
      }
    },
    "size.sm": {
      "props": {
        "Size": "sm",
        "Variant": "default"
      }
    },
    "state.disabled": {
