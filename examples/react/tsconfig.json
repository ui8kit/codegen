{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@ui": ["../../generated/ui/index.ts"],
      "@ui/*": ["../../generated/ui/*"]
    }
  },
  "include": ["src/**/*.tsx", "script/**/*.tsx", "../data/**/*.json"]
}
