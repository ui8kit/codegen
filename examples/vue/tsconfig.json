{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "paths": {
      "@ui": ["../../generated/ui/index.vue.ts"],
      "@ui/*": ["../../generated/ui/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../data/**/*.json"]
}
