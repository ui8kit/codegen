{
  "name": "@ui8kit/codegen",
  "version": "0.1.0",
  "description": "Spec-driven codegen engine for UI8Kit ui/ primitives: one typed render contract, seven runtimes (Templ, React, Svelte 5, Vue 3, SolidJS, Latte, Twig).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ui8kit-codegen": "./bin/ui8kit-codegen.js"
  },
  "scripts": {
    "generate": "bun src/infrastructure/cli.ts generate --out generated",
    "generate:latte-bundle": "bun src/application/generate-latte-bundle.ts",
    "check": "bun src/infrastructure/cli.ts check",
    "dev:templ": "cd examples && bun run dev:templ",
    "dev:react": "cd examples && bun run dev:react",
    "dev:svelte": "cd examples && bun run dev:svelte",
    "dev:vue": "cd examples && bun run dev:vue",
    "dev:solid": "cd examples && bun run dev:solid",
    "dev:latte": "cd examples && bun run dev:latte",
    "dev:twig": "cd examples && bun run dev:twig",
    "build:html": "cd examples && bun run build:html",
    "build:css": "cd examples && bun run build:css",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:generated": "bun run generate && bun x tsc -p tsconfig.generated.json",
    "verify": "bun run check && bun x tsc --noEmit && bun run typecheck:generated && bun test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@babel/core": "7",
    "@babel/preset-typescript": "7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/server-renderer": "^3.5.13",
    "babel-preset-solid": "^1.9.12",
    "bun-types": "^1.3.14",
    "parse5": "^7.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solid-js": "^1.9.5",
    "svelte": "^5.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.0.4",
    "vue": "^3.5.13"
  }
}
